# Path to your mdbase task notes collection
MDBASE_TASKNOTES_PATH=/path/to/your/collection

# HTTP server port
PORT=3000

# OAuth 2.0 configuration
OAUTH_ISSUER_URL=https://your-tenant.auth0.com/
OAUTH_AUDIENCE=https://your-api-identifier

# MCP server URL (used for OAuth protected resource metadata)
SERVER_URL=http://localhost:3000/mcp

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000
